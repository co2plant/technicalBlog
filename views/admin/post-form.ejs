<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/github-markdown-css/5.2.0/github-markdown-light.min.css">
    <style>
        .markdown-editor {
            font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
        }
        .tab-button.active {
            @apply bg-blue-600 text-white;
        }
        .tab-button {
            @apply bg-gray-200 text-gray-700 px-4 py-2 rounded-t-lg font-medium;
        }
        .markdown-body {
            box-sizing: border-box;
            min-width: 200px;
            max-width: none;
            margin: 0;
            padding: 16px;
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- 네비게이션 바 -->
    <nav class="bg-blue-600 text-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <h1 class="text-xl font-bold">
                        <% if (action === 'create') { %>새 게시글 작성<% } else { %>게시글 수정<% } %>
                    </h1>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/admin" class="hover:bg-blue-700 px-3 py-2 rounded-md text-sm font-medium">
                        <i class="fas fa-arrow-left mr-2"></i>대시보드로
                    </a>
                    <a href="/" class="hover:bg-blue-700 px-3 py-2 rounded-md text-sm font-medium">
                        <i class="fas fa-home mr-2"></i>블로그 홈
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <form method="POST" action="<% if (action === 'create') { %>/admin/posts<% } else { %>/admin/posts/<%= post.id %><% } %>">
            <!-- 기본 정보 입력 -->
            <div class="bg-white shadow rounded-lg p-6 mb-6">
                <h2 class="text-lg font-medium text-gray-900 mb-4">기본 정보</h2>
                
                <div class="space-y-4">
                    <div>
                        <label for="title" class="block text-sm font-medium text-gray-700">제목</label>
                        <input type="text" 
                               id="title" 
                               name="title" 
                               value="<%= post ? post.title : '' %>"
                               required 
                               class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 px-3 py-2 border">
                    </div>
                    
                    <div>
                        <label for="excerpt" class="block text-sm font-medium text-gray-700">요약 (선택사항)</label>
                        <input type="text" 
                               id="excerpt" 
                               name="excerpt" 
                               value="<%= post ? post.excerpt : '' %>"
                               placeholder="게시글의 간단한 요약을 입력하세요..."
                               class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 px-3 py-2 border">
                    </div>
                </div>
            </div>

            <!-- 콘텐츠 입력 (마크다운 에디터) -->
            <div class="bg-white shadow rounded-lg p-6 mb-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-lg font-medium text-gray-900">콘텐츠</h2>
                    <div class="flex space-x-1">
                        <button type="button" id="editTab" class="tab-button active">
                            <i class="fas fa-edit mr-1"></i>편집
                        </button>
                        <button type="button" id="previewTab" class="tab-button">
                            <i class="fas fa-eye mr-1"></i>미리보기
                        </button>
                    </div>
                </div>

                <!-- 편집 영역 -->
                <div id="editArea">
                    <textarea id="content" 
                              name="content" 
                              required 
                              rows="20"
                              placeholder="마크다운으로 콘텐츠를 작성하세요...

예시:
# 제목

## 소제목

이것은 **굵은 텍스트**이고, 이것은 *기울임 텍스트*입니다.

### 코드 예시
```javascript
function hello() {
    console.log('Hello, World!');
}
```

- 첫 번째 항목
- 두 번째 항목
- 세 번째 항목"
                              class="markdown-editor w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 px-3 py-2 border resize-none"><%= post ? post.content : '' %></textarea>
                </div>

                <!-- 미리보기 영역 -->
                <div id="previewArea" class="hidden">
                    <div id="preview" class="markdown-body border border-gray-300 rounded-md min-h-96 bg-white">
                        <p class="text-gray-500 p-4">미리보기가 여기에 표시됩니다...</p>
                    </div>
                </div>
            </div>

            <!-- 액션 버튼 -->
            <div class="flex justify-between">
                <a href="/admin" class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2 rounded-lg font-medium">
                    <i class="fas fa-times mr-2"></i>취소
                </a>
                <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg font-medium">
                    <i class="fas fa-save mr-2"></i>
                    <% if (action === 'create') { %>게시글 작성<% } else { %>수정 완료<% } %>
                </button>
            </div>
        </form>
    </div>

    <script>
        // 탭 전환 기능
        const editTab = document.getElementById('editTab');
        const previewTab = document.getElementById('previewTab');
        const editArea = document.getElementById('editArea');
        const previewArea = document.getElementById('previewArea');
        const contentTextarea = document.getElementById('content');
        const preview = document.getElementById('preview');

        editTab.addEventListener('click', () => {
            editTab.classList.add('active');
            previewTab.classList.remove('active');
            editArea.classList.remove('hidden');
            previewArea.classList.add('hidden');
        });

        previewTab.addEventListener('click', () => {
            previewTab.classList.add('active');
            editTab.classList.remove('active');
            previewArea.classList.remove('hidden');
            editArea.classList.add('hidden');
            updatePreview();
        });

        // 마크다운 미리보기 업데이트
        function updatePreview() {
            const content = contentTextarea.value;
            if (content.trim() === '') {
                preview.innerHTML = '<p class="text-gray-500 p-4">미리보기가 여기에 표시됩니다...</p>';
            } else {
                // Marked.js 설정
                marked.setOptions({
                    breaks: true,
                    gfm: true,
                    sanitize: false
                });
                preview.innerHTML = marked.parse(content);
            }
        }

        // 실시간 미리보기 업데이트 (디바운스)
        let previewTimeout;
        contentTextarea.addEventListener('input', () => {
            clearTimeout(previewTimeout);
            previewTimeout = setTimeout(() => {
                if (!previewArea.classList.contains('hidden')) {
                    updatePreview();
                }
            }, 300);
        });

        // 키보드 단축키
        document.addEventListener('keydown', (e) => {
            // Ctrl+S: 저장
            if (e.ctrlKey && e.key === 's') {
                e.preventDefault();
                document.querySelector('form').submit();
            }
            // Ctrl+P: 미리보기 전환
            if (e.ctrlKey && e.key === 'p') {
                e.preventDefault();
                previewTab.click();
            }
            // Ctrl+E: 편집 전환
            if (e.ctrlKey && e.key === 'e') {
                e.preventDefault();
                editTab.click();
            }
        });

        // 페이지 로드 시 초기 미리보기 설정
        document.addEventListener('DOMContentLoaded', () => {
            // 수정 모드일 때 초기 미리보기 준비
            <% if (post) { %>
                updatePreview();
            <% } %>
        });
    </script>
</body>
</html>
